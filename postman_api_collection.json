{
  "info": {
    "name": "PracticHub API",
    "description": "Colección completa de la API PracticHub. \n\n**Flujo recomendado:**\n1. Ejecutar **Auth → Login** (guarda el token automáticamente)\n2. Crear datos base: Empresa → Profesor → Curso Académico → Alumno\n3. Crear Seguimiento asignando empresa, profesor, curso y alumno\n4. Crear Partes Diarios y Valoraciones sobre el seguimiento\n5. Probar rutas específicas de Alumno, Profesor y Empresa",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "1" },
    { "key": "profesor_id", "value": "1" },
    { "key": "empresa_id", "value": "1" },
    { "key": "curso_id", "value": "1" },
    { "key": "seguimiento_id", "value": "1" },
    { "key": "parte_id", "value": "1" },
    { "key": "valoracion_id", "value": "1" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Registro, login y logout. El Login guarda el token automáticamente en la variable {{token}}.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Demo\",\n  \"email\": \"admin@practicHub.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "description": "Registra un nuevo usuario. Solo necesario la primera vez."
          }
        },
        {
          "name": "Login ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado: ' + json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@practicHub.com\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Hace login y guarda el token automáticamente en {{token}}. Ejecutar siempre primero."
          }
        },
        {
          "name": "Usuario autenticado (GET /user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/user", "host": ["{{base_url}}"], "path": ["user"] },
            "description": "Devuelve los datos del usuario autenticado."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] },
            "description": "Invalida el token actual."
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Estadísticas generales",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/dashboard/stats", "host": ["{{base_url}}"], "path": ["dashboard", "stats"] },
            "description": "Devuelve contadores (empresas, alumnos, profesores, partes...) y actividad reciente."
          }
        }
      ]
    },
    {
      "name": "🏢 Empresas",
      "description": "CRUD de empresas.",
      "item": [
        {
          "name": "Listar empresas (paginado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/empresas?per_page=15",
              "host": ["{{base_url}}"],
              "path": ["empresas"],
              "query": [
                { "key": "per_page", "value": "15", "description": "Registros por página" },
                { "key": "only_active", "value": "true", "description": "Solo empresas activas", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Listado público (sin auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/empresas/listado", "host": ["{{base_url}}"], "path": ["empresas", "listado"] },
            "description": "Endpoint público para que los alumnos vean las empresas disponibles."
          }
        },
        {
          "name": "Crear empresa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('empresa_id', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"TechNova Solutions\",\n  \"cif\": \"B12345678\",\n  \"direccion\": \"Calle Gran Via 45, Madrid\",\n  \"telefono\": \"912345678\",\n  \"email\": \"info@technova.com\",\n  \"sector\": \"Tecnología\",\n  \"tutor_empresa\": \"Laura Gómez\",\n  \"email_tutor\": \"laura@technova.com\",\n  \"activo\": true\n}"
            },
            "url": { "raw": "{{base_url}}/empresas", "host": ["{{base_url}}"], "path": ["empresas"] },
            "description": "Guarda el ID en {{empresa_id}} automáticamente."
          }
        },
        {
          "name": "Ver empresa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/empresas/{{empresa_id}}", "host": ["{{base_url}}"], "path": ["empresas", "{{empresa_id}}"] }
          }
        },
        {
          "name": "Editar empresa",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"911111111\",\n  \"activo\": true\n}"
            },
            "url": { "raw": "{{base_url}}/empresas/{{empresa_id}}", "host": ["{{base_url}}"], "path": ["empresas", "{{empresa_id}}"] },
            "description": "Actualización parcial. Solo enviar los campos a modificar."
          }
        },
        {
          "name": "Eliminar empresa",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/empresas/{{empresa_id}}", "host": ["{{base_url}}"], "path": ["empresas", "{{empresa_id}}"] }
          }
        }
      ]
    },
